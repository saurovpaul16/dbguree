{
  "name": "dbguree",
  "version": "0.1.0",
  "description": "Local-first SQL workbench with on-device AI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "webpack --watch --mode development",
    "dev": "concurrently \"npm run dev:renderer\" \"electron .\"",
    "build": "webpack --mode production",
    "build:bundle": "npm run build && electron-builder --mac --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:all": "npm run build && electron-builder --mac --win --publish never"
  },
  "build": {
    "appId": "com.dbguree.app",
    "productName": "DBGuree",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "src/index.html"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "extraResources": [
        { "from": "../backend-dist/backend", "to": "backend-dist", "filter": ["**/*"] }
      ]
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "extraResources": [
        { "from": "../backend-win", "to": "backend-win", "filter": ["**/*"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DBGuree"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "ag-grid-community": "^31.3.0",
    "ag-grid-react": "^31.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.0",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "style-loader": "^3.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
